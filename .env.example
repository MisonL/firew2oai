# firew2oai Environment Variables
# Copy this file to .env and customize values

# Listen port (default: 39527)
PORT=39527

# Listen host (default: all interfaces)
# HOST=127.0.0.1

# API Key authentication
# Supports: single key, comma-separated keys, JSON file path, or inline JSON
# Examples:
#   API_KEY=CHANGE_ME_sk-your-secure-key-here
#   API_KEY=CHANGE_ME_sk-key1,CHANGE_ME_sk-key2
#   API_KEY=/path/to/tokens.json
API_KEY=CHANGE_ME_sk-your-secure-key-here

# Upstream request timeout in seconds (default: 120)
TIMEOUT=120

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Show thinking process for thinking models (default: false)
SHOW_THINKING=false

# CORS origins, comma-separated or * for all (default: *)
CORS_ORIGINS=*

# Global rate limit per key per minute (0 = disabled, default: 0)
RATE_LIMIT=0

# IP whitelist, comma-separated IPs/CIDRs (empty = allow all, default: 127.0.0.1,::1)
IP_WHITELIST=127.0.0.1,::1

# Number of trusted reverse proxies for X-Forwarded-For (0 = trust none, default: 0)
# Set to 1 if behind one reverse proxy (e.g., nginx)
# TRUSTED_PROXY_COUNT=0
